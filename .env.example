# SGC Digital - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# MSSQL Database Configuration
# ===========================================
MSSQL_SERVER=localhost
MSSQL_DATABASE=SGCDigital
MSSQL_USER=sa
MSSQL_PASSWORD=your_password_here
MSSQL_PORT=1433

# Set to 'true' for Azure SQL Database
MSSQL_ENCRYPT=false

# Set to 'false' in production with valid SSL certificates
MSSQL_TRUST_CERT=true

# ===========================================
# File Storage Configuration
# ===========================================
# Path where uploaded files will be stored
# Can be absolute path or relative to project root
FILE_STORAGE_PATH=./uploads

# ===========================================
# Application Settings
# ===========================================
# Base URL for the application (used for email links, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session expiry in days
SESSION_EXPIRY_DAYS=7

# ===========================================
# Optional: Email Configuration (for notifications)
# ===========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_password
# SMTP_FROM=noreply@sgc.gov.bb
